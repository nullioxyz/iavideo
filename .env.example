APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
LANGUAGE_COUNTRY_HEADERS=CF-IPCountry,CloudFront-Viewer-Country,X-Country-Code

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iavideo
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
MEDIA_DISK=public
MEDIA_PREFIX=
UPLOADS_PROVIDER=local
UPLOADS_TEMP_DISK=local
UPLOADS_LOCAL_MEDIA_DISK=public
UPLOADS_LOCAL_MEDIA_PREFIX=
UPLOADS_S3_MEDIA_DISK=spaces
UPLOADS_S3_MEDIA_PREFIX=inkai
FILAMENT_FILESYSTEM_DISK=

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ENDPOINT=
AWS_URL=

DO_SPACE_KEY=
DO_SPACE_SECRET=
DO_SPACE_REGION=nyc3
DO_SPACE_BUCKET=
DO_SPACE_ENDPOINT=
DO_SPACE_URL=
DO_SPACE_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
REPLICATE_WEBHOOK_SECRET=
REPLICATE_OUTPUT_ALLOWED_HOSTS=cdn.replicate.com,replicate.delivery
PAYMENTS_DEFAULT_PROVIDER=fakepay
PAYMENTS_CURRENCY=USD
PAYMENTS_WEBHOOK_SECRET=
PAYMENTS_FAKE_CHECKOUT_STATUS=pending

# Realtime / Socket.IO (client)
VITE_WS_ENABLED=true
VITE_WS_HOST=localhost
VITE_WS_PORT=6001
VITE_WS_SCHEME=http
VITE_WS_AUTH_ENDPOINT=/api/broadcasting/auth

# Laravel Echo Server (server)
# Use backend internal URL reachable from socket server container/process.
LARAVEL_ECHO_SERVER_AUTH_HOST=http://laravel.test
LARAVEL_ECHO_SERVER_AUTH_ENDPOINT=/api/broadcasting/auth
LARAVEL_ECHO_SERVER_HOST=0.0.0.0
LARAVEL_ECHO_SERVER_PORT=6001
LARAVEL_ECHO_SERVER_PROTO=http
LARAVEL_ECHO_SERVER_REDIS_HOST=redis
LARAVEL_ECHO_SERVER_REDIS_PORT=6379
LARAVEL_ECHO_SERVER_DEV_MODE=true

# Operations: smoke checks & threshold alerts
OPS_SMOKE_REQUIRE_REDIS=false
OPS_ALERT_QUEUE_PENDING_JOBS=200
OPS_ALERT_FAILED_JOBS_24H=30
OPS_ALERT_PREDICTION_FAILURES_24H=60
OPS_ALERT_AI_LATENCY_P95_MS_24H=120000
